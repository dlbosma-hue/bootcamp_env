      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2816, 7760]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  try {\n    const text = item.json.report_text || '';\n    const chunkSize = 1900;\n    const chunks = [];\n    for (let i = 0; i < text.length; i += chunkSize) {\n      chunks.push(text.slice(i, i + chunkSize));\n    }\n\n    // Parse overall_score from report_text if API didn't return it\n    let score = parseFloat(item.json.overall_score);\n    if (!score || isNaN(score)) {\n      const match = text.match(/Overall Average[\\s\\S]*?\\*\\*([\\d.]+)\\/10\\*\\*/);\n      score = match ? parseFloat(match[1]) : 0;\n    }\n\n    results.push({\n      json: {\n        ...item.json,\n        overall_score: score,\n        report_blocks: chunks\n      }\n    });\n  } catch (err) {\n    results.push({\n      json: {\n        ...item.json,\n        overall_score: item.json.overall_score || 0,\n        report_blocks: [],\n        parse_error: err.message\n      }\n    });\n  }\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3024, 7760],
