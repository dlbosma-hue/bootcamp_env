            { "name": "summary", "stringValue": "={{ $('HTTP Request to FastAPI1').first().json.summary }}" },
            { "name": "report_path", "stringValue": "={{ $('HTTP Request to FastAPI1').first().json.report_path }}" },
            { "name": "report_text", "stringValue": "={{ $('HTTP Request to FastAPI1').first().json.report_text }}" },
            { "name": "harm_flags", "stringValue": "={{ $('HTTP Request to FastAPI1').first().json.harm_flags?.join(', ') ?? 'None' }}" },
            { "name": "community_scores", "stringValue": "={{ JSON.stringify($('HTTP Request to FastAPI1').first().json.community_scores ?? {}) }}" },
            { "name": "triggered_by", "stringValue": "={{ $('Prepare Input1').first().json.triggered_by }}" }
