OPENAI_API_KEY=your_openai_api_key_here

# Gmail address you're sending FROM
EMAIL_SENDER=your.email@gmail.com

# Gmail App Password (not your login password)
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on your Google account
EMAIL_PASSWORD=your_16_character_app_password

# Email address to receive the daily digest (can be same as EMAIL_SENDER)
EMAIL_RECIPIENT=your.email@gmail.com

# Optional: paste resume/reference letter text here to use secrets instead of committed files
# RESUME_TEXT=
# ARBEITSZEUGNIS_TEXT=
