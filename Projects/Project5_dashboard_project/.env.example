# Copy this file to .env and fill in your keys — never commit .env to git

# OpenAI (required for agent + LLM-as-judge)
OPENAI_API_KEY=sk-...

# LangSmith (required for dataset creation + monitoring)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=fitness-retention-p5
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com  # EU accounts only — remove for US
